{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "start-gg-parser",
  "version": "0.1.0",
  "identifier": "com.cb.start-gg-parser",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "start-gg-parser",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/chintanbhatt2/start_gg_parser/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxOTYyNEZERUU5MDA1Q0EKUldUS0JaRHUvU1NXa2V3OEVOdTlDTHN1R3lTUjJGN0g0TWdtMHpYUDdjYmRZalZzMmkxUmFzUmIK"
    }
  }
}
